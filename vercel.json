{
  "rewrites": [
    {
      "source": "/proxy/chatbot/:path*",
      "destination": "/api/chatbotProxy?targetPath=:path*"
    },
    {
      "source": "/proxy/warehouse/:path*",
      "destination": "/api/warehouseProxy?targetPath=:path*"
    },
    {
      "source": "/proxy/rme/:path*",
      "destination": "https://smartclinic-rekam-medis.onrender.com/:path*"
    },
    {
      "source": "/proxy/ai/:path*",
      "destination": "https://dashboard-ai-9k65.onrender.com/:path*"
    },
    {
      "source": "/proxy/internal/:path*",
      "destination": "https://db-posqris-cpgii-production.up.railway.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
